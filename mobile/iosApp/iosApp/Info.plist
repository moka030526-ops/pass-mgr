<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>pass-mgr</string>
	<key>CFBundleDisplayName</key>
	<string>pass-mgr</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>0.1</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<!-- Deliberately offline: no networking, no background modes. -->
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!--
	  NOTE (audit R-13): `NSFileProtectionComplete` is NOT a valid Info.plist key — it
	  is a file attribute / entitlement value, so the entry that used to live here was a
	  silent no-op. Data protection is now applied per-file in ContentView.swift
	  (FileProtectionType.complete on the vault directory). For app-wide protection also
	  add the Data Protection capability (the
	  `com.apple.developer.default-data-protection = NSFileProtectionComplete`
	  entitlement) in an .entitlements file — verify on a Mac.
	-->
</dict>
</plist>
