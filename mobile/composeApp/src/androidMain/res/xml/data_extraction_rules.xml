<?xml version="1.0" encoding="utf-8"?>
<!--
  Exclude ALL app data from BOTH off-device channels on Android 12+ (targetSdk 31+):
    * cloud-backup   — Auto Backup / adb backup (also covered by allowBackup="false")
    * device-transfer — the newer device-to-device migration channel, which
                        allowBackup="false" does NOT govern.
  The encrypted vault (vault.pmv + volume/ + manifest/) lives under filesDir/vault/
  (the "file" domain). This app is deliberately offline and the ciphertext must never
  leave the original device, so a migration cannot copy it to a new (possibly later
  compromised) phone for offline two-password brute force. path="." = the whole domain.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
